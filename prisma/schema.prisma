generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  /// SHA-256 hex digest of the active password-reset token; raw token never stored
  resetPasswordTokenHash String?
  resetPasswordExpiresAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business         Business?
  createdPayments  Payment[]

  @@index([resetPasswordTokenHash])
}

// ─── Business ────────────────────────────────────────────────────────────────

model Business {
  id          String   @id @default(cuid())
  ownerUserId String   @unique
  owner       User     @relation(fields: [ownerUserId], references: [id])
  name        String
  taxId       String?
  /// Flat address line (used in document snapshots)
  address     String?
  city        String?
  postalCode  String?
  country     String?  @default("IL")
  phone       String?
  email       String?
  logo        String?
  /// "osek_murshe" | "osek_patur" | "chevra"
  taxType     String   @default("osek_murshe")
  /// "general" | "photography" | "contractor" | "consulting" | "retail" | "other"
  businessType String  @default("general")
  /// VAT rate percentage, e.g. 17.00
  vatRate     Decimal  @db.Decimal(5, 2) @default(17)
  currency    String   @default("ILS")
  invoiceNumberPrefix        String @default("INV-")
  invoiceStartNumber         Int    @default(1)
  receiptNumberPrefix        String @default("REC-")
  receiptStartNumber         Int    @default(1)
  quoteNumberPrefix          String @default("QUO-")
  quoteStartNumber           Int    @default(1)
  invoiceReceiptNumberPrefix String @default("INVR-")
  invoiceReceiptStartNumber  Int    @default(1)
  /// Send a notification email to business.email when a document is issued
  sendIssueNotificationEmail Boolean @default(false)
  /// Default "small print" / terms text copied into every new QUOTE at creation time
  quoteTermsText             String? @db.Text
  /// Optional customer-facing WhatsApp template for quote approval links
  approvalWhatsappMessageTemplate String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customers Customer[]
  documents Document[]
  payments   Payment[]
  counters   DocumentCounter[]
  savedItems SavedItem[]
  googleCalendarConnection BusinessGoogleCalendarConnection?
}

// ─── Google Calendar connection ──────────────────────────────────────────────

/// Owner-side Google Calendar OAuth tokens for a business. Tokens are stored
/// AES-256-GCM encrypted using ENCRYPTION_KEY; raw tokens never hit the wire
/// outside of the OAuth callback / refresh paths.
model BusinessGoogleCalendarConnection {
  id            String   @id @default(cuid())
  businessId    String   @unique
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  googleEmail   String?
  /// AES-256-GCM ciphertext of the access token (iv:authTag:ciphertext, hex)
  accessToken   String   @db.Text
  /// AES-256-GCM ciphertext of the refresh token; null when Google did not return one
  refreshToken  String?  @db.Text
  tokenExpiry   DateTime?
  calendarId    String   @default("primary")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── SavedItem ────────────────────────────────────────────────────────────────

model SavedItem {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id])
  name         String
  description  String?
  defaultPrice Decimal  @db.Decimal(12, 2) @default(0)
  unit         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId])
}

// ─── Customer ────────────────────────────────────────────────────────────────

model Customer {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  /// Individual's full name — at least one of fullName / companyName must be set
  fullName    String?
  /// Company or organisation name
  companyName String?
  email       String?
  phone       String?
  address     String?
  taxId       String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents Document[]
  payments  Payment[]

  @@unique([businessId, phone])
  @@index([businessId])
}

// ─── Document ────────────────────────────────────────────────────────────────

enum DocumentType {
  QUOTE
  INVOICE
  RECEIPT
  INVOICE_RECEIPT
  CREDIT_NOTE
}

enum DocumentStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
  DELETED
}

model Document {
  id              String         @id @default(cuid())
  businessId      String
  business        Business       @relation(fields: [businessId], references: [id])
  customerId      String
  customer        Customer       @relation(fields: [customerId], references: [id])
  sourceDocumentId String?       @unique
  sourceDocument  Document?      @relation("DocumentCreditNoteSource", fields: [sourceDocumentId], references: [id])
  creditNote      Document?      @relation("DocumentCreditNoteSource")
  relatedDocumentId String?
  relatedDocument  Document?      @relation("DocumentRelated", fields: [relatedDocumentId], references: [id])
  derivedDocuments Document[]     @relation("DocumentRelated")
  type            DocumentType
  status          DocumentStatus @default(DRAFT)
  /// Null until document is issued
  number          String?
  issueDate       DateTime?
  dueDate         DateTime?
  notes           String?
  internalNotes   String?
  currency        String         @default("ILS")
  isTaxInclusive  Boolean        @default(false)
  /// VAT rate at time of creation, e.g. 17.00 for 17%
  vatRateSnapshot Decimal        @db.Decimal(5, 2) @default(17)

  // Customer snapshot — null until issued, populated at issue time
  customerName    String?
  customerEmail   String?
  customerAddress String?
  customerTaxId   String?

  // Business snapshot — null until issued, populated at issue time
  businessName    String?
  businessTaxId   String?
  businessAddress String?

  // Photography quote fields — null unless businessType=photography and type=QUOTE
  eventDate     DateTime?
  eventLocation String?
  eventHours    Decimal?  @db.Decimal(5, 2)
  eventTime     String?
  /// Quote-only "small print" / terms — snapshot copied from business.quoteTermsText at quote creation
  quoteTermsText String? @db.Text
  receiptAmountReceived   Decimal? @db.Decimal(12, 2)
  receiptPaymentMethod    String?
  receiptPaymentReference String?
  receiptCheckNumber      String?
  receiptCheckBank        String?
  receiptCheckBranch      String?
  receiptCheckAccount     String?
  receiptCheckDueDate     DateTime?

  // Money — Decimal only, never Float
  subtotalAmount Decimal @db.Decimal(12, 2) @default(0)
  taxAmount      Decimal @db.Decimal(12, 2) @default(0)
  totalAmount    Decimal @db.Decimal(12, 2) @default(0)
  amountPaid     Decimal @db.Decimal(12, 2) @default(0)
  amountDue      Decimal @db.Decimal(12, 2) @default(0)

  /// SHA256 hex digest of immutable issued-document data — set at issue time, never changed
  issuedHash  String?  @db.Char(64)

  // ─── Customer-facing online approval (QUOTE only) ──────────────────────────
  /// SHA-256 hex digest of the active customer-approval token — raw token never stored
  approvalTokenHash         String?
  approvalTokenCreatedAt    DateTime?
  approvalTokenExpiresAt    DateTime?
  /// Set the moment the customer submits the approval form
  approvedAt                DateTime?
  /// Full name typed by the customer at approval time
  approvedByName            String?
  approvalIp                String?
  approvalUserAgent         String?
  approvalSignatureDataUrl  String?   @db.Text
  approvalTermsAccepted     Boolean   @default(false)

  /// Set when an event was successfully created in the owner's Google Calendar.
  /// Used to make calendar-event creation idempotent across re-approvals.
  googleCalendarEventId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    DocumentItem[]
  payments Payment[]

  @@unique([businessId, number])
  @@index([businessId])
  @@index([businessId, status])
  @@index([customerId])
  @@index([approvalTokenHash])
}

model DocumentItem {
  id             String   @id @default(cuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  lineIndex      Int      @default(0)
  description    String
  quantity       Decimal  @db.Decimal(10, 3)
  unitPrice      Decimal  @db.Decimal(12, 2)
  discountAmount Decimal  @db.Decimal(12, 2) @default(0)
  subtotalAmount Decimal  @db.Decimal(12, 2)
  /// Tax rate as a percentage, e.g. 17.00 for 17%
  taxRate        Decimal  @db.Decimal(5, 2)
  taxAmount      Decimal  @db.Decimal(12, 2)
  totalAmount    Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Payment ─────────────────────────────────────────────────────────────────

model Payment {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id])
  documentId      String
  document        Document @relation(fields: [documentId], references: [id])
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  createdByUserId String
  createdBy       User     @relation(fields: [createdByUserId], references: [id])
  amount          Decimal  @db.Decimal(12, 2)
  /// cash | check | bank_transfer | credit_card | other
  method          String
  paymentDate     DateTime
  reference       String?
  checkNumber     String?
  checkBank       String?
  checkBranch     String?
  checkAccount    String?
  checkDueDate    DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([businessId])
  @@index([documentId])
  @@index([customerId])
}

// ─── Sequential numbering ─────────────────────────────────────────────────────

model DocumentCounter {
  id         String       @id @default(cuid())
  businessId String
  business   Business     @relation(fields: [businessId], references: [id])
  type       DocumentType
  lastNumber Int          @default(0)

  @@unique([businessId, type])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

/// Immutable audit trail — rows are never updated or deleted.
model AuditLog {
  id         String   @id @default(cuid())
  /// "document" | "payment" | "customer"
  entityType String
  entityId   String
  /// "create" | "issue" | "cancel" | "payment_add" | "payment_delete"
  action     String
  /// Nullable — system actions (e.g. seeding) have no user
  userId     String?
  businessId String
  /// JSON snapshot of the relevant entity at the time of the action
  payload    Json
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([entityType, entityId])
}
