# ─── Setup ────────────────────────────────────────────────────────────────────
#
# Prisma CLI reads .env (not .env.local).
# Next.js reads both .env and .env.local (.env.local takes priority).
#
# Recommended local setup — create BOTH files from this template:
#
#   Git Bash / Mac / Linux:
#     cp .env.example .env
#     cp .env.example .env.local
#
#   Windows cmd:
#     copy .env.example .env
#     copy .env.example .env.local
#
# Then edit .env.local and change NEXTAUTH_SECRET to a real random value:
#   openssl rand -base64 32     (Mac/Linux/Git Bash)
#
# ─── Local database (Docker) ──────────────────────────────────────────────────
#
# Start the local Postgres container:
#   docker compose up -d
#
# Then run migrations:
#   npx prisma migrate dev --name init
#   npx prisma db seed
#
# ─────────────────────────────────────────────────────────────────────────────

# Supabase + Vercel recommended:
# DATABASE_URL: Supavisor transaction mode (port 6543) with pgbouncer=true
# DIRECT_URL: direct database URL or session pooler URL for Prisma migrations
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (optional) ─────────────────────────────────────────────────────────
# Leave SMTP_HOST unset to use stub mode (logs instead of sending)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
